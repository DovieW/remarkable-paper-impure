{
  "name": "paperboard-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm -r build && pnpm -r check",
    "test": "pnpm -r test",
    "dev:relay": "pnpm --filter @paperboard/relay dev",
    "paperboard": "pnpm --filter @paperboard/cli start --",
    "mcp": "pnpm --filter @paperboard/mcp start",
    "home-assistant": "pnpm --filter @paperboard/home-assistant start"
  }
}
