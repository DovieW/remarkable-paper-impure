{
  "allow_local_shell": false,
  "macros": [
    { "label": "TMUX", "key": "space", "ctrl": true },
    { "label": "C-C", "key": "c", "ctrl": true },
    { "label": "C-D", "key": "d", "ctrl": true },
    { "label": "C-Z", "key": "z", "ctrl": true },
    { "label": "C-L", "key": "l", "ctrl": true },
    { "label": "C-R", "key": "r", "ctrl": true }
  ],
  "profiles": [
    {
      "id": "tailscale-host",
      "label": "Tailnet host",
      "mode": "tailscale-ssh",
      "user": "example-user",
      "host": "example-host"
    },
    {
      "id": "windows-via-wsl",
      "label": "Windows PowerShell via WSL",
      "mode": "tailscale-key",
      "user": "example-user",
      "host": "example-wsl-host",
      "identity_file": "/home/root/.ssh/paperterm_ed25519",
      "session": "windows-powershell"
    },
    {
      "id": "lan-host",
      "label": "Trusted LAN host",
      "mode": "ssh",
      "user": "example-user",
      "host": "192.0.2.10",
      "port": 22,
      "identity_file": "/home/root/.ssh/paperterm_ed25519"
    }
  ]
}
