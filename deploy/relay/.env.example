PAPERBOARD_TS_HOSTNAME=paperboard
PAPERBOARD_TS_AUTHKEY=tskey-auth-REPLACE_WITH_EPHEMERAL_ONE_TIME_KEY
PAPERBOARD_PUBLIC_BASE_URL=https://paperboard.example-tailnet.ts.net
PAPERBOARD_LOCAL_PORT=8787
PAPERBOARD_LOCAL_ADMIN_PORT=8788
PAPERBOARD_SECRET_GID=1000
PAPERBOARD_DATA_DIR=/mnt/example/containers/paperboard/data
PAPERBOARD_TS_STATE_DIR=/mnt/example/containers/paperboard/tailscale
PAPERBOARD_TABLET_SSH_DIR=/mnt/example/containers/paperboard/ssh
PAPERBOARD_TABLET_BRIDGE_CONFIG=/mnt/example/containers/paperboard/tablet-bridge.conf
# Optional absolute secret paths. Defaults are under the ignored repository secrets/ directory.
# PAPERBOARD_MASTER_KEY_FILE=/secure/path/paperboard-master-key
# PAPERBOARD_ADMIN_TOKEN_FILE=/secure/path/paperboard-admin-token
