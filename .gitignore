# Never commit local device credentials or private keys.
.env
.env.*
!.env.example
config/device.env
config/*.local
*.pem
*.key

# Device captures and backups may contain private documents or identifiers.
backups/
captures/
build/

# Owner-specific tablet, network, and recovery notes. Use PERSONAL.example.md
# as the public-safe template; PERSONAL.md must remain local.
PERSONAL.md
